# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_MULTIPLE_DATABASES=app,prefect
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/app

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Prefect ───────────────────────────────────────────────
PREFECT_API_URL=http://prefect-server:4200/api
PREFECT_AUTH_STRING=admin:changeme

# ── App ───────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
